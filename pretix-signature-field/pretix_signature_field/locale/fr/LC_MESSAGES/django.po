msgid "Handwritten signature"
msgstr "Signature manuscrite"

msgid "Signature Field"
msgstr "Champ signature"

msgid "Adds a handwritten signature question type to the checkout process. Buyers can sign directly in their browser using a touch or mouse gesture."
msgstr "Ajoute un type de question « signature manuscrite » au processus de commande. Les acheteurs peuvent signer directement dans leur navigateur à l'aide d'un geste tactile ou à la souris."

msgid "Clear signature"
msgstr "Effacer la signature"

msgid "Draw your signature in the box above"
msgstr "Dessinez votre signature dans le cadre ci-dessus"

msgid "Invalid signature format. Please draw your signature in the box."
msgstr "Format de signature invalide. Veuillez dessiner votre signature dans le cadre."

msgid "Invalid signature data."
msgstr "Données de signature invalides."

msgid "The signature image is too large. Please clear and re-sign."
msgstr "L'image de la signature est trop volumineuse. Veuillez effacer et resigner."

msgid "Signature"
msgstr "Signature"

msgid "(signature on file)"
msgstr "(signature enregistrée)"
